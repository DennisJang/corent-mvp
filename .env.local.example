# CoRent dev-only local environment.
# Copy this file to .env.local and fill values manually.
# Never commit .env.local.
# Never paste real keys into chat.

ENABLE_ANALYTICS_BETA=false

# Supabase dev project: corent-dev
# Region: ap-northeast-2
SUPABASE_URL=https://<project-ref>.supabase.co

# Used for Supabase Auth SSR session reads only.
# This is not a service/admin key.
SUPABASE_ANON_KEY=<paste-dev-anon-key-locally-only>

# Server-only. Used only by the Phase 1 analytics writer.
# Never prefix this with NEXT_PUBLIC_.
# Never expose this to client code.
SUPABASE_SERVICE_ROLE_KEY=<paste-dev-service-role-key-locally-only>

# Comma-separated founder emails allowed to access /admin/dashboard.
# Example:
# FOUNDER_ADMIN_EMAIL_ALLOWLIST=founder@example.com
FOUNDER_ADMIN_EMAIL_ALLOWLIST=<founder-email@example.com>

# Optional public Supabase values.
# Only add NEXT_PUBLIC_* values if a future client-side feature explicitly requires them.
# Phase 1 admin auth and analytics should not need these in browser code.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

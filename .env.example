# CoRent — Phase 1 Validation Beta env example.
#
# Never commit a real secret to this file or to .env.local.
# Real values are set in the Vercel project's environment settings.
#
# All names below MUST stay non-NEXT_PUBLIC unless explicitly noted.
# A NEXT_PUBLIC_* name is shipped to the browser bundle. The service-role
# key, the admin allowlist, and the ingest shared secret must NEVER be
# `NEXT_PUBLIC_*`.

# ---------------------------------------------------------------------
# Phase 1 feature flag.
#
# Default: off. Only the literal string "true" enables the analytics
# write path. Any other value, missing, or empty leaves the path off.
# ---------------------------------------------------------------------
ENABLE_ANALYTICS_BETA=false

# ---------------------------------------------------------------------
# Supabase — server-only.
#
# - SUPABASE_URL: project URL. Region: ap-northeast-2 (Seoul). Read by
#   both the analytics writer (service-role) and the founder admin SSR
#   auth client (anon).
# - SUPABASE_SERVICE_ROLE_KEY: bypasses RLS. Server-only. NEVER prefix
#   with NEXT_PUBLIC_*. Read only by src/server/analytics/supabase.ts
#   and src/server/admin/dashboard-data.ts. NEVER used for user
#   session / auth.
# - SUPABASE_ANON_KEY: server-only. Read only by the founder admin SSR
#   auth client (src/server/admin/supabase-ssr.ts) to validate the
#   magic-link session cookie. Browser-safe in principle, but kept
#   un-prefixed so the auth surface stays server-only in Phase 1.5.
# ---------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------
# Public Supabase keys (browser-safe).
#
# Phase 1 does not instantiate a Supabase client in the browser, but the
# names are reserved for future use. Anon key alone cannot reach the
# Phase 1 tables — RLS is deny-by-default with no policies.
# ---------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------
# Founder admin allowlist — server-only.
#
# Comma-separated list of emails. Empty / missing means EVERY admin
# request fails closed (404). Lowercase or mixed case both work.
# ---------------------------------------------------------------------
FOUNDER_ADMIN_EMAIL_ALLOWLIST=<founder-email@example.com>

# ---------------------------------------------------------------------
# Analytics ingest shared secret — server-only.
#
# Optional cheap forgery defense for /api/events (token rotates). NOT a
# security boundary; the rate limit + sanitizer + RLS are the actual
# defenses. Documented for forward use.
# ---------------------------------------------------------------------
ANALYTICS_INGEST_SHARED_SECRET=

# ---------------------------------------------------------------------
# Phase 2 backend mode — server-only.
#
# Default: missing / empty / "mock" → safe mock + localStorage path
# (no DB writes). Only the literal string "supabase" enables the
# Phase 2 server-only Supabase marketplace adapters; even then,
# production builds fall back to "mock" automatically. This is a single
# narrow switch, not a feature-flag framework. See
# docs/phase2_backend_integration_draft.md.
# ---------------------------------------------------------------------
CORENT_BACKEND_MODE=mock

# ---------------------------------------------------------------------
# Vercel project setting (NOT an app-readable env var).
#
# `VERCEL_DEPLOYMENT_PROTECTION_PASSWORD` is configured in the Vercel
# project dashboard and applied to the /admin/* route group as a soft
# outer gate. The actual auth boundary is the Supabase magic-link +
# allowlist check in src/server/admin/auth.ts.
# ---------------------------------------------------------------------
